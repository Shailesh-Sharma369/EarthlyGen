# Ruhi AI Integration - Environment Configuration
# Copy this file to .env in backend directory

# ==============================
# EXPRESS BACKEND
# ==============================
PORT=5002
NODE_ENV=development

# ==============================
# PYTHON AI SERVER
# ==============================
PYTHON_CONTROLLER_URL=http://localhost:9000
PYTHON_SERVER_PORT=9000

# ==============================
# BRAIN API (LLM Inference)
# ==============================
# For local development:
BRAIN_API_URL=http://localhost:8000/decide

# For RunPod cloud (update after deployment):
# BRAIN_API_URL=https://your-runpod-url.io/decide

# ==============================
# BACKEND APIs
# ==============================
BACKEND_BASE_URL=http://localhost:5002

# ==============================
# DATABASE
# ==============================
MONGODB_URI=mongodb://localhost:27017/socialcart
# OR use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/socialcart

# ==============================
# JWT & SECURITY
# ==============================
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRATION=7d

# ==============================
# AI CONFIGURATION
# ==============================
DEBUG=0
RUHI_PERSONALITY=helpful_assistant  # Can be: helpful_assistant, consultant, expert

# MOCK MODE - Test without Brain API
MOCK_MODE=false  # Set to true to use test data instead of calling Python AI
# When MOCK_MODE=true:
# - All queries return predefined test responses
# - No need for Brain API, Python server, or Mistral LLM
# - Perfect for frontend testing and demos
# Set to false to use real AI

# ==============================
# OPTIONAL: Email Configuration
# ==============================
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@socialcart.com

# ==============================
# OPTIONAL: OAuth
# ==============================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
