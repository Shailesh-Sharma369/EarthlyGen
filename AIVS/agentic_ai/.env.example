# ========================================
# AGENTIC AI CONTROLLER CONFIGURATION
# ========================================

# Assistant branding
AI_NAME=Ruhi

# Brain API (Mistral LLM Remote Inference)
# Colab + ngrok: https://<ngrok-subdomain>.ngrok-free.app/generate
# Local brain testing: http://localhost:8000/generate
BRAIN_API_URL=https://unseditious-gloria-soothfastly.ngrok-free.dev/generate

# Optional explicit health URL (if omitted, derived automatically)
BRAIN_HEALTH_URL=https://unseditious-gloria-soothfastly.ngrok-free.dev/health

# Brain call tuning
BRAIN_API_TIMEOUT=60
BRAIN_API_RETRIES=2
BRAIN_AUTH_HEADER=Authorization
# BRAIN_API_KEY=your_secret_if_brain_is_protected

# Backend API (SocialCart - E-commerce + Social Media)
# Local development: http://localhost:5002
# Production: https://your-backend-url.com
BACKEND_BASE_URL=http://localhost:5002

# Local Python AI server port (controller wrapper for Node backend)
PYTHON_SERVER_PORT=9000

# ========================================
# OPTIONAL: Database Configuration
# ========================================
# For local session memory persistence (future)
# MONGODB_URI=mongodb://localhost:27017/agentic_ai
# REDIS_URL=redis://localhost:6379

# ========================================
# DEBUG MODE
# ========================================
# Set to 1 for verbose logging
DEBUG=0

# ========================================
# OPTIONAL: Voice Features (TTS/STT)
# ========================================
# Install local deps if you want voice endpoints:
# pip install pyttsx3 SpeechRecognition
